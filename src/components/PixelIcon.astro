---
import sword from 'pixelarticons/svg/sword.svg?raw';
import card from 'pixelarticons/svg/card-text.svg?raw';
import chess from 'pixelarticons/svg/chess.svg?raw';
import target from 'pixelarticons/svg/target.svg?raw';
import users from 'pixelarticons/svg/users.svg?raw';

type IconName = 'action' | 'cards' | 'tactics' | 'shooter' | 'coop';
const { name, label } = Astro.props as { name: IconName; label?: string };
const artwork = { action: sword, cards: card, tactics: chess, shooter: target, coop: users }[name];
const svg = artwork.replace('<svg ', '<svg class="pixel-pack-icon" aria-hidden="true" ');
---
<span class="pixel-icon" role={label ? 'img' : undefined} aria-label={label} set:html={svg} />
