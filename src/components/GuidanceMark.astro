---
const { variant = 'check' } = Astro.props as { variant?: 'check' | 'cross' };
const path = variant === 'check'
  ? 'M0 6h3v3h3v3h3V9h3V6h3V3h-3v3H9v3H6V6H3v3H0z'
  : 'M0 3h3v3h3V3h3V0h4v3h-3v3h3v4h-3v3h3v3H9v-3H6v-3H3v3H0v-3h3V6H0z';
---
<span class:list={['pixel-mark', variant === 'check' ? 'pixel-check' : 'pixel-cross']} aria-hidden="true"><svg viewBox="0 0 16 16"><path d={path} /></svg></span>
