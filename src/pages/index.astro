---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import PixelIcon from '../components/PixelIcon.astro';
import PixelButton from '../components/PixelButton.astro';
import PixelBadge from '../components/PixelBadge.astro';
import GuidanceMark from '../components/GuidanceMark.astro';
import { games, guideTopics } from '../data/games';
const styles = [['Action','action','Fast reflexes, close combat, pure adrenaline.'],['Cards','cards','Deckbuilding and tactical card combat.'],['Tactics','tactics','Grid-based strategy and careful planning.'],['Shooter','shooter','Guns, bullets, and screen-clearing chaos.'],['Co-op','coop','Team up with friends for chaotic co-op runs.']] as const;
const color = {Action:'var(--action)',Cards:'var(--cards)',Tactics:'var(--tactics)',Shooter:'var(--shooter)','Co-op':'var(--coop)'};
---
<BaseLayout title="Rogue On Switch — Find your next great run">
  <SiteHeader />
  <main class="shell">
    <section class="hero"><div><h1>Find your next<br />great run on<br /><em>Nintendo Switch.</em></h1><p>Rogue On Switch is an independent editorial directory<br />of roguelikes and roguelites playable on Nintendo Switch.<br />Curated lists, honest takes, and practical filters<br />to help you find games you’ll love.</p><PixelButton href="#browse" label="Explore games" /></div><div class="hero-art" aria-label="Pixel-art dungeon explorer at a ruined gate"></div></section>
    <section class="section"><p class="kicker">Browse by playstyle</p><div class="playstyles">{styles.map(([name,icon,copy]) => <a class="playstyle" href={`/genre/${name.toLowerCase()}/`} style={`--color:${color[name]}`}><PixelIcon name={icon} label={`${name} playstyle`} /><b>{name}</b><span>{copy}</span></a>)}</div></section>
    <section class="section"><p class="kicker">Editor's pick</p><div class="feature"><div class="feature-visual"><h2>Hades</h2></div><div class="feature-copy"><h2>Defy the god of the dead.</h2><p>As you hack and slash through the ever-shifting Underworld. Tight combat, meaningful choices, and unforgettable characters make every run feel epic.</p><PixelBadge label="Action" color="var(--action)" /></div><div class="feature-guidance"><div><h3>Best for</h3><p><GuidanceMark />Players who enjoy fast combat and fluid movement<br /><GuidanceMark />Those who love strong progression between runs<br /><GuidanceMark />Anyone who wants a story that unfolds as they play</p></div><div><h3 class="skip">Skip if</h3><p><GuidanceMark variant="cross" />You prefer turn-based or slow-paced combat<br /><GuidanceMark variant="cross" />You want long, careful planning between runs<br /><GuidanceMark variant="cross" />You’re not into frequent restarts on failure</p></div></div></div></section>
    <section class="section" id="browse"><div class="directory-head"><p class="kicker">Browse games</p><div class="filters"><button class="filter">All genres</button><button class="filter">Any run length</button><button class="filter">Any price</button><button class="filter">Co-op</button><button class="filter">Sort: Featured</button></div><a class="reset" href="#browse">Reset filters</a></div><table class="game-table"><thead><tr><th>Game</th><th>Run length</th><th>Price (USD)</th><th>Genre</th><th>Playstyle</th><th>Co-op</th></tr></thead><tbody>{games.slice(0,5).map(game => <tr><td><a href={`/games/${game.slug}/`}>{game.title}</a></td><td>{game.runLength}</td><td>{game.price}</td><td>{game.genre}, {game.classification}</td><td><PixelBadge label={game.playstyle} color={color[game.playstyle]} /></td><td>{game.coOp}</td></tr>)}</tbody></table></section>
    <section class="section"><div class="field-guide"><div><PixelIcon name="book" label="Open field guide" /><p class="kicker">The field guide</p><h2>Useful answers, not store copy.</h2><p>Deep dives, genre explainers, and practical guides to help you get the most out of roguelikes.</p></div>{guideTopics.slice(0,3).map(([,title,copy]) => <a href={`/best/${title.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/-$/,'')}/`}><h3>{title}</h3><p>{copy}</p></a>)}</div></section>
  </main>
  <footer class="footer"><a class="brand" href="/"><strong>ROGUE</strong><span>ON SWITCH</span></a><p>Rogue On Switch is an independent editorial directory and is not affiliated with, endorsed by, or sponsored by any game developer, publisher, or platform holder.</p><span>About　 Contact　 Editorial Policy　 Privacy</span></footer>
</BaseLayout>
