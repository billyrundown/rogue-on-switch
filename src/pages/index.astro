---
import BaseLayout from '../layouts/BaseLayout.astro'; import SiteHeader from '../components/SiteHeader.astro'; import { games, guideTopics } from '../data/games';
const styles = [['Action','Fast reflexes, close combat, pure adrenaline.'],['Cards','Deckbuilding and tactical card combat.'],['Tactics','Grid-based strategy and careful planning.'],['Shooter','Guns, bullets, and screen-clearing chaos.'],['Co-op','Team up with friends for chaotic runs.']] as const;
const color = {Action:'var(--action)',Cards:'var(--cards)',Tactics:'var(--tactics)',Shooter:'var(--shooter)','Co-op':'var(--coop)'};
---
<BaseLayout title="Rogue On Switch — Find your next great run"><SiteHeader /><main class="shell"><section class="hero"><div><h1>Find your next<br />great run on<br /><em>Nintendo Switch.</em></h1><p>Rogue On Switch is an independent editorial directory for players who want a better way to find their next roguelike or roguelite.</p><a class="button" href="#browse">Explore games →</a></div><div class="hero-art" aria-label="Pixel-art dungeon explorer at a ruined gate"></div></section><section class="section"><p class="kicker">Browse by playstyle</p><div class="playstyles">{styles.map(([name,copy]) => <a class="playstyle" href={`/genre/${name.toLowerCase()}/`} style={`--color:${color[name]}`}><b>{name}</b><span>{copy}</span></a>)}</div></section><section class="section"><p class="kicker">Editor's pick</p><div class="feature"><div class="feature-visual"><h2>Hades</h2></div><div class="feature-copy"><h2>Make every escape attempt count.</h2><p>Fast combat, meaningful choices, and an underworld worth learning make Hades a rare action roguelite that works as brilliantly in short handheld sessions as it does for an all-night run.</p><span class="type" style="--type:var(--action)">Action</span></div><div class="feature-guidance"><h3>Best for</h3><p>Players who enjoy fast combat and a story that unfolds between runs.</p><h3 class="skip">Skip if</h3><p>You prefer turn-based planning or want a low-stakes challenge.</p></div></div></section><section class="section" id="browse"><div class="directory-head"><p class="kicker">Browse games</p><div class="filters"><button class="filter">All genres</button><button class="filter">Any run length</button><button class="filter">Any price</button></div></div><table class="game-table"><thead><tr><th>Game</th><th>Run length</th><th>Price</th><th>Genre</th><th>Playstyle</th><th>Co-op</th></tr></thead><tbody>{games.slice(0,8).map(game => <tr><td><a href={`/games/${game.slug}/`}>{game.title}</a></td><td>{game.runLength}</td><td>{game.price}</td><td>{game.genre}</td><td><span class="type" style={`--type:${color[game.playstyle]}`}>{game.playstyle}</span></td><td>{game.coOp}</td></tr>)}</tbody></table></section><section class="section"><div class="field-guide"><div><p class="kicker">The field guide</p><h2>Useful answers, not store copy.</h2><p>Deep dives, genre explainers, and practical guides for making a better pick.</p></div>{guideTopics.slice(0,3).map(([,title,copy]) => <a href={`/best/${title.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/-$/,'')}/`}><h3>{title}</h3><p>{copy}</p></a>)}</div></section></main><footer class="footer"><a class="brand" href="/"><strong>ROGUE</strong><span>ON SWITCH</span></a><p>Rogue On Switch is an independent editorial directory. It is not affiliated with, endorsed by, or sponsored by Nintendo or any game developer, publisher, or platform holder.</p><span>Editorial policy · Privacy</span></footer></BaseLayout>
