---
import BaseLayout from '../../layouts/BaseLayout.astro'; import SiteHeader from '../../components/SiteHeader.astro'; import { games } from '../../data/games'; import { getResearchAssetsBySiteSlug, researchFacts } from '../../data/research';
const researchAssets = await getResearchAssetsBySiteSlug();
---
<BaseLayout title="All roguelikes on Nintendo Switch | Rogue On Switch"><SiteHeader /><main class="shell"><p class="breadcrumb"><a href="/">Home</a> / Games</p><section class="detail"><p class="kicker">The directory</p><h1>Every run starts somewhere.</h1><p>Browse our launch directory of Switch roguelikes, roguelites, and clearly labelled run-based hybrids.</p></section><table class="game-table"><thead><tr><th>Game</th><th>Run length</th><th>Price</th><th>Genre</th><th>Playstyle</th><th>Co-op</th></tr></thead><tbody>{games.map(seed => { const asset = researchAssets.get(seed.slug); const game = researchFacts(seed, asset?.entry) ?? seed; return <tr><td><a class="game-cell" href={`/games/${game.slug}/`}>{asset?.cover && <img class="game-thumbnail" src={asset.cover} alt="" />}<span>{game.title}</span></a></td><td>{game.runLength}</td><td>{game.price}</td><td>{game.genre}</td><td>{game.playstyle}</td><td>{game.coOp}</td></tr>})}</tbody></table></main></BaseLayout>
